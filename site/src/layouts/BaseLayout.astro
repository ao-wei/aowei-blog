---
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import OnekoPatrol from '../components/OnekoPatrol.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = '敖炜的博客',
  description = '个人文章、项目入口和长期记录。',
} = Astro.props;

const pageTitle = title === '敖炜的博客' ? title : `${title} | Aowei 博客`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <nav class="nav" aria-label="主导航">
          <a class="brand" href="/">
            <span class="brand-mark" aria-hidden="true">A</span>
            <span>敖炜的博客</span>
          </a>
          <div class="nav-links">
            <a href="/profile">关于我</a>
            <a href="/blog">文章</a>
            <a href="/projects">项目</a>
            <a href="/about">关于网站</a>
          </div>
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <OnekoPatrol />
      <footer class="site-footer">
        <div class="footer-inner">
          <span>© {new Date().getFullYear()} Aowei</span>
          <span>使用 Astro 和 Markdown 构建。</span>
        </div>
      </footer>
    </div>
  </body>
</html>

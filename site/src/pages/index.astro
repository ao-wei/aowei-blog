---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CatCompanion from '../components/CatCompanion.astro';
import EntryCard from '../components/EntryCard.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.published.getTime() - a.data.published.getTime())
  .slice(0, 4);

const projects = (await getCollection('projects'))
  .filter((project) => !project.data.draft)
  .sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
  .slice(0, 4);
---

<BaseLayout
  title="Aowei Blog"
  description="Personal notes, technical essays, and project links."
>
  <section class="section hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">Personal Blog</p>
        <h1>记录学习、工程实践和一些有意思的项目。</h1>
        <p class="lead">
          这里会沉淀源码阅读、AI 工程、比赛复盘、工具构建，以及后续可以直接访问的项目入口。
        </p>
        <div class="actions">
          <a class="button primary" href="/blog">阅读文章</a>
          <a class="button" href="/projects">查看项目</a>
        </div>
      </div>
      <CatCompanion />
    </div>
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Latest Writing</p>
        <h2>最近文章</h2>
      </div>
      <a href="/blog">全部文章</a>
    </div>
    {
      posts.length > 0 ? (
        <div class="grid">
          {posts.map((post) => (
            <EntryCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              date={post.data.published}
              tags={post.data.tags}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">还没有公开文章。</p>
      )
    }
  </section>

  <section class="section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Project Index</p>
        <h2>项目入口</h2>
      </div>
      <a href="/projects">全部项目</a>
    </div>
    {
      projects.length > 0 ? (
        <div class="grid">
          {projects.map((project) => (
            <EntryCard
              href={`/projects/${project.id}`}
              title={project.data.title}
              description={project.data.description}
              status={project.data.status}
              tags={project.data.tags}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">还没有公开项目。</p>
      )
    }
  </section>
</BaseLayout>
